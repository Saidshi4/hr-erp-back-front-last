# Copy to .env and fill with strong unique values before `docker compose up`.
# Never commit a real .env file.

POSTGRES_PASSWORD=change-me-strong-db-password
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
ENCRYPTION_SECRET_KEY=change-me-32-char-encryption-key!!
ISAPI_API_KEY=change-me-shared-backend-isapi-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000
SPRING_PROFILES_ACTIVE=prod
COMPUTER_IP=192.168.1.102
